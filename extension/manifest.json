{
  "manifest_version": 3,
  "name": "Claude Browser Bridge",
  "version": "2.0.0",
  "description": "Secure browser bridge — connect any AI agent to your Chrome via your own relay server.",
  "permissions": [
    "tabs",
    "activeTab",
    "scripting",
    "storage",
    "debugger",
    "webNavigation",
    "downloads",
    "alarms"
  ],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Claude Browser Bridge",
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "128": "icon.png"
  },
  "sandbox": {
    "pages": ["sandbox.html"]
  }
}
